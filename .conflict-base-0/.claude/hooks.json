{
  "hooks": {
    "PostToolUse": [
      {
        "name": "Domain Purity Check",
        "command": "bash .claude/hooks/domain-purity-check.sh",
        "severity": "warning"
      },
      {
        "name": "SQL Injection Prevention",
        "command": "bash .claude/hooks/sql-injection-prevention.sh",
        "severity": "blocker"
      },
      {
        "name": "Router Boundary Check",
        "command": "bash .claude/hooks/router-boundary-check.sh",
        "severity": "warning"
      },
      {
        "name": "No print() in Production",
        "command": "bash .claude/hooks/no-print-in-production.sh",
        "severity": "warning"
      },
      {
        "name": "Environment Variable Leak",
        "command": "bash .claude/hooks/env-variable-leak.sh",
        "severity": "warning"
      }
    ]
  }
}
