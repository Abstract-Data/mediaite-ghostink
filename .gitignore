# Pipeline & local data (see src/forensics/config — default data_dir is ./data)
data/raw/*
data/features/*
data/analysis/*
data/reports/*
data/pipeline/*
# Runtime data subdirs produced by pre-registration, calibration, and survey runs.
data/preregistration/
data/calibration/
data/survey/
!data/.gitkeep
# DB artifacts often live directly under data/ (e.g. articles.db)
data/*.db
data/*.db-journal
data/*.db-wal
data/*.db-shm
data/*.sqlite
data/*.sqlite3
data/*.duckdb
*.duckdb

# Logs & scratch
*.log
logs/
scratch/

# Editor & OS
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/settings.json

# Hook / agent local artifacts
.claude/hooks/logs/
.cursor/hooks/state/
