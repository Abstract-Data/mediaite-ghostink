# Python
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
ENV/
env/

# uv / Hatch (build outputs; keep uv.lock committed)
dist/
build/

# Test & quality
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
.tox/
.nox/
.coverage
.coverage.*
coverage.xml
coverage.json
htmlcov/
junit.xml
test-results.xml

# Environment & secrets
.env
.env.*
!.env.example

# Notebooks
.ipynb_checkpoints/

# Pipeline & local data (see src/forensics/config — default data_dir is ./data)
data/raw/*
# Per-author feature parquets — research deliverables, tracked via Git LFS
# (see .gitattributes). Subdirs and other artifacts under data/features/ stay
# ignored.
data/features/*
!data/features/*.parquet
# Embedding batches (per-author *.npz) and the canonical manifest — research
# deliverables tracked via Git LFS. Transient per-author shards
# (`<slug>_manifest.jsonl`) and rev-pin backups (`manifest.jsonl.pre-*`) stay
# ignored by virtue of not being explicitly re-included.
data/embeddings/**
!data/embeddings/
!data/embeddings/manifest.jsonl
!data/embeddings/*/
!data/embeddings/*/batch.npz
# Archive directories created when an embedding model-revision mismatch
# triggers a full re-embed (timestamped suffix per archive event).
data/embeddings_archive_*/
# Per-author analysis artifacts — change-points, drift, hypothesis tests,
# convergence windows, imputation stats, monthly centroids, time series.
# Tracked for reproducibility (small JSON via git, parquet/npz via LFS).
data/analysis/*
!data/analysis/*.json
!data/analysis/*.npz
!data/analysis/*.parquet
# Phase 15 — keep provenance artifacts committed (profile preservation, etc)
!data/analysis/provenance/
!data/analysis/provenance/*
# Section-residualized sensitivity sub-tree (referenced from run_metadata.json)
!data/analysis/sensitivity/
!data/analysis/sensitivity/**
data/reports/*
data/pipeline/*
# Probability-model outputs (per-author Parquet + sidecars)
data/probability/
# Phase 10 synthetic baseline tree (JSON + per-article npy/embeddings)
data/ai_baseline/
# Runtime data subdirs produced by pre-registration, calibration, and survey runs.
data/preregistration/*
# Phase 15 — keep pre-registration amendments committed
!data/preregistration/amendment_*.md
# Phase 15 J3/J6 follow-up — keep the operator-fillable lock template committed
# so the analyze CLI sees a non-mismatching exploratory state by default.
!data/preregistration/preregistration_lock.json
!data/preregistration/.gitignore
data/calibration/
data/survey/
# Phase 15 — bench baselines are committed provenance artifacts
!data/bench/
!data/bench/*.json
!data/.gitkeep
# JSONL exports and scrape/discovery logs at repo data root
data/articles.jsonl
data/authors_manifest.jsonl
data/scrape_errors.jsonl
data/extraction_warnings.jsonl
data/coauthored_articles.jsonl
# FUSE/overlay temp files (e.g. editors touching data/ on sshfs)
data/.fuse_hidden*
# Ad-hoc local review / export notes dropped next to corpus artifacts
data/adversarial_review*.md
# DB artifacts often live directly under data/ (e.g. articles.db)
data/*.db
data/*.db-journal
data/*.db-wal
data/*.db-shm
data/*.sqlite
data/*.sqlite3
data/*.duckdb
*.duckdb

# Logs & scratch
*.log
logs/
scratch/

# Editor & OS
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/settings.json

# Hook / agent local artifacts
.claude/hooks/logs/
.claude/worktrees/
.claude/scheduled_tasks.lock
.cursor/hooks/state/
.gitnexus

/.quarto/
**/*.quarto_ipynb

# Quarto execute cache (regenerated by `quarto render --execute`)
_freeze/
